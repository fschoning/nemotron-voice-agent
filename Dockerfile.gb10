FROM nvcr.io/nvidia/pytorch:26.02-py3

# 1. System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-dev python3.12-venv git && \
    rm -rf /var/lib/apt/lists/*

# 2. Setup uv for rapid dependency installation
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# 3. Core dependencies
RUN uv pip install --system --break-system-packages --no-cache \
    pyyaml typing_extensions sympy filelock networkx jinja2

# 4. Install torchaudio for CUDA 13.0
RUN uv pip install --system --break-system-packages --no-cache torchaudio \
    --index-url https://download.pytorch.org/whl/cu130 \
    --no-deps

# 5. Lock NeMo to the exact March 2024 commit tested by the repository
RUN git clone https://github.com/NVIDIA/NeMo.git /opt/nemo && \
    cd /opt/nemo && git checkout 644201898480ec8c8d0a63 && \
    uv pip install --system --break-system-packages --no-cache Cython hydra-core>=1.3.0 omegaconf>=2.3 pytorch-lightning>=2.0 && \
    uv pip install --system --break-system-packages --no-cache -e ".[asr,tts]"

# 6. Install Inference backends (INCLUDING LLM SERVER DEPS)
RUN uv pip install --system --break-system-packages --no-cache \
    tokenizers>=0.19 fastapi uvicorn[standard] pydantic>=2.0 prometheus_client websockets>=12.0 loguru>=0.7.0 httpx>=0.25.0 \
    vllm "llama-cpp-python[server]" sse-starlette pydantic-settings

# 7. Install the Nemotron Voice Agent source code
WORKDIR /workspace
COPY pyproject.toml README.md ./
COPY src/ ./src/
RUN uv pip install --system --break-system-packages --no-cache -e .
RUN mkdir -p /workspace/models

# 8. THE IRONCLAD LOCK: Force restore PyTorch to CUDA 13.0 AND strictly pin NumPy last
RUN pip install --break-system-packages --no-cache-dir --force-reinstall torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu130 && \
    pip install --break-system-packages --no-cache-dir "numpy<2.3"
